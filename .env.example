# ── Auth (Google OAuth via NextAuth) ─────────────────────────────
# TODO: create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (and your prod domain)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── Payments (Razorpay) ──────────────────────────────────────────
# TODO: get keys at https://dashboard.razorpay.com/app/keys
# The order-create API lives in app/api/create-order/route.ts
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Dev bypass ───────────────────────────────────────────────────
# "true" lets you click through signup + payment without real keys.
# It is ALWAYS off in production builds unless you explicitly set it.
# Set to "false" (or remove) before going live.
NEXT_PUBLIC_DEV_BYPASS=true
